# .env.example
# Copy to .env and fill in your values
# NEVER commit .env — it's in .gitignore

GCP_PROJECT=skylens-india
GCS_BUCKET=skylens-datalake-skylens-india
PUBSUB_TOPIC=flights-topic
PUBSUB_SUBSCRIPTION=flights-sub
BQ_DATASET_RAW=skylens_raw
BQ_DATASET_DBT=skylens_dbt
REGION=asia-south1

# Slack webhook for Airflow failure alerts
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Path to your GCP service account JSON key
# Generated by setup_gcp.sh — never commit this file
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json
